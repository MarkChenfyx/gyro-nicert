GYRO_ENV=development

# Optional RQData credentials. If these are not set, the data layer can read
# vn.py style settings from GYRO_VT_SETTING_PATH or a local .vntrader/vt_setting.json.
GYRO_RQDATA_USERNAME=
GYRO_RQDATA_PASSWORD=
GYRO_VT_SETTING_PATH=

# Strategy generation.
GYRO_LLM_PROVIDER=openai_compatible
GYRO_LLM_API_KEY=
GYRO_LLM_BASE_URL=https://api.openai.com/v1
GYRO_LLM_MODEL=gpt-4o-mini
GYRO_LLM_TIMEOUT=60
GYRO_LLM_TEMPERATURE=0.1

# DeepSeek example:
# GYRO_LLM_PROVIDER=deepseek
# GYRO_LLM_BASE_URL=https://api.deepseek.com/v1
# GYRO_LLM_MODEL=deepseek-chat

# Kimi example:
# GYRO_LLM_PROVIDER=kimi
# GYRO_LLM_BASE_URL=https://api.moonshot.cn/v1
# GYRO_LLM_MODEL=moonshot-v1-8k

# Backward-compatible OpenAI-style aliases are also accepted:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=60
